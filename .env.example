# Port auf dem Host, der auf Port 80 im Container gemappt wird.
# Default: 8080 → erreichbar via http://localhost:8080
HOST_PORT=8080

# Adresse, an die Caddy intern bindet. Standard ":80" lässt den Container
# auf Port 80 lauschen — passend zum Port-Mapping oben.
# Für direktes Auto-TLS hier eine Domain setzen (z.B. f2g.example.com)
# UND im Compose 443:443 zusätzlich publishen.
SITE_ADDRESS=:80
